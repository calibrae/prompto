# /etc/prompto/env — EnvironmentFile for the systemd service.

# Path to the host inventory TOML.
PROMPTO_INVENTORY=/etc/prompto.toml

# HTTP listen address. 0.0.0.0 for LAN access, 127.0.0.1 for localhost-only.
PROMPTO_BIND=0.0.0.0:6337

# Comma-separated Host-header allowlist (DNS rebinding protection).
# Defaults to localhost only — override to accept remote clients.
# Set to "*" to disable the check entirely (only behind a trusted proxy/firewall).
PROMPTO_ALLOWED_HOSTS=*

# Path to the ssh binary. Override only if the system ssh is not on PATH.
PROMPTO_SSH_BIN=ssh

# Default per-command timeout (seconds).
PROMPTO_DEFAULT_TIMEOUT_SECS=30

# Per-step timeout in the vm_stop fallback chain (seconds).
PROMPTO_STOP_VM_STEP_SECS=30

# Token-savings analytics — set to 0/false to disable usage tracking entirely.
PROMPTO_GAIN_ENABLED=true

# Append-only JSONL log of every tool invocation (for `prompto gain`).
PROMPTO_USAGE_LOG=/var/lib/prompto/usage.jsonl

# Tracing level.
RUST_LOG=prompto=info
